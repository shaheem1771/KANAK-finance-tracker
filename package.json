{
  "name": "kanank",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "src",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "start:client": "npm --prefix src run dev",
    "start:server": "npm --prefix server run dev",
    "build": "npm --prefix src run build",
    "lint": "npm --prefix src run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
